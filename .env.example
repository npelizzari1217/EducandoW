# ── Server ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=educandow
# DATABASE_URL: SOLO para `prisma migrate dev` del schema TENANT (sandbox de dev).
# NO se usa en runtime. DEBE ser una DB DISTINTA del master: si apunta al master,
# las migraciones de tenant lo contaminan. Usá una DB dedicada.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/educandow_tenant_dev

# ── JWT ─────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── Master Database ──────────────────────────────────────
# Master DB: institutions, users, RBAC. El runtime usa ESTA URL para todo:
# conecta al master y deriva las conexiones por-tenant swapeando el nombre de
# la DB por el de cada institucion (educandow_<uuid>). Mantener el master LIMPIO
# (sin tablas de tenant).
MASTER_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/educandow_master

# ── Encryption ──────────────────────────────────────────
# AES-256-GCM key: exactly 32 bytes (32 ASCII chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=change-me-to-32-bytes-exactly!!

# ── Bcrypt ──────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── Credenciales ROOT ────────────────────────────────────
# Usuario ROOT creado por el seed/bootstrap. Definir antes de correr el seed.
ROOT_EMAIL=root@tu-dominio.com
ROOT_PASSWORD=cambiame-por-una-clave-fuerte
