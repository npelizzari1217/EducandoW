# ── Server ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/educandow

# ── JWT ─────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── Bcrypt ──────────────────────────────────────────────
BCRYPT_ROUNDS=12
