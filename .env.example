# ── Server ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=educandow
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/educandow

# ── JWT ─────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── Master Database ──────────────────────────────────────
# Connection string for the master database (institutions, users, RBAC)
MASTER_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/educandow_master

# ── Encryption ──────────────────────────────────────────
# AES-256-GCM key: exactly 32 bytes (32 ASCII chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=change-me-to-32-bytes-exactly!!

# ── Bcrypt ──────────────────────────────────────────────
BCRYPT_ROUNDS=12
