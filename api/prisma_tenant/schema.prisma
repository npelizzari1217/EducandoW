// ── Subject Grading (Fase 4) ───────────────────────────────

// Snapshot of the period structure for one Materia×Curso×Ciclo. Immutable copy. (AD-4)
model SubjectGradingPeriod {
  id            String  @id @default(uuid())
  courseCycleId String  @map("course_cycle_id")   // → CourseCycle.uuid
  subjectId     String  @map("subject_id")
  periodOrdinal Int     @map("period_ordinal")     // = GradingPeriodTemplateItem.sortOrder at snapshot time
  periodName    String  @map("period_name")        // = GradingPeriodTemplateItem.name at snapshot time

  courseCycle CourseCycle @relation(fields: [courseCycleId], references: [uuid], onDelete: Restrict)
  subject     Subject     @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@unique([courseCycleId, subjectId, periodOrdinal])
  @@index([courseCycleId, subjectId])
  @@map("subject_grading_periods")
}

// Alphanumeric subject-level period grade + per-period pedagogical flags (AD-3).
model SubjectPeriodGrade {
  id                String               @id @default(uuid())
  studentId         String               @map("student_id")
  courseCycleId     String               @map("course_cycle_id")   // → CourseCycle.uuid
  subjectId         String               @map("subject_id")
  periodOrdinal     Int                  @map("period_ordinal")     // matches SubjectGradingPeriod.periodOrdinal
  gradeScaleValueId String?              @map("grade_scale_value_id")
  gradeCode         String?              @map("grade_code")          // snapshot of the code
  internalStatus    GradeInternalStatus? @map("internal_status")
  // Per-period pedagogical flags (AD-3)
  pa                Boolean              @default(false)
  ppi               Boolean              @default(false)
  pp                Boolean              @default(false)

  student     Student          @relation(fields: [studentId],         references: [id], onDelete: Cascade)
  courseCycle CourseCycle      @relation(fields: [courseCycleId],     references: [uuid], onDelete: Restrict)
  subject     Subject          @relation(fields: [subjectId],         references: [id], onDelete: Cascade)
  gradeValue  GradeScaleValue? @relation(fields: [gradeScaleValueId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@unique([studentId, courseCycleId, subjectId, periodOrdinal])
  @@index([courseCycleId, subjectId])
  @@index([studentId])
  @@map("subject_period_grades")
}

// Four final grade instances, one row per (student, courseCycle, subject, type). (AD-2)
enum SubjectFinalGradeType {
  FINAL
  DICIEMBRE
  MARZO
  DEFINITIVA
}

// Year-end condicion for Secundario (grading-secundario / D1).
// Nullable — Primario rows carry NULL without error (COND-R4).
// LIBRE cannot be auto-derived; must be set explicitly by the teacher (COND-R2).
enum SubjectFinalGradeCondicion {
  REGULAR
  PREVIA
  LIBRE
}

model SubjectFinalGrade {
  id                String                        @id @default(uuid())
  studentId         String                        @map("student_id")
  courseCycleId     String                        @map("course_cycle_id")   // → CourseCycle.uuid
  subjectId         String                        @map("subject_id")
  type              SubjectFinalGradeType
  gradeScaleValueId String?                       @map("grade_scale_value_id")
  gradeCode         String?                       @map("grade_code")
  internalStatus    GradeInternalStatus?          @map("internal_status")
  passed            Boolean?
  /// Secundario year-end verdict. Nullable — Primario rows get NULL naturally (COND-R4, D5).
  condicion         SubjectFinalGradeCondicion?

  student     Student          @relation(fields: [studentId],         references: [id],   onDelete: Cascade)
  courseCycle CourseCycle      @relation(fields: [courseCycleId],     references: [uuid], onDelete: Restrict)
  subject     Subject          @relation(fields: [subjectId],         references: [id],   onDelete: Cascade)
  gradeValue  GradeScaleValue? @relation(fields: [gradeScaleValueId], references: [id],   onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@unique([studentId, courseCycleId, subjectId, type])
  @@index([courseCycleId, subjectId])
  @@index([studentId])
  @@map("subject_final_grades")
}

// ── Grading Periods ────────────────────────────────────────

model GradingPeriodTemplate {
  id        String   @id @default(uuid())
  name      String              // "Trimestral", "Cuatrimestral"
  level     Int                 // EducationalLevelCode (1-4)
  modality  Int    @default(0)  // EducationalModalityCode (0-2)
  active    Boolean @default(true)
  deletedAt DateTime?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items GradingPeriodTemplateItem[]

  @@unique([level, modality, name])
  @@index([level])
  @@map("grading_period_templates")
}

model GradingPeriodTemplateItem {
  id         String @id @default(uuid())
  templateId String @map("template_id")
  name       String              // "1° Trimestre", "2° Cuatrimestre"
  sortOrder  Int                 // ≥ 1, unique within template

  template GradingPeriodTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  dates    GradingPeriodDate[]
  competencyPeriodValuations CompetencyPeriodValuation[]

  @@unique([templateId, sortOrder])
  @@unique([templateId, name])
  @@index([templateId])
  @@map("grading_period_template_items")
}

model GradingPeriodDate {
  id        String   @id @default(uuid())
  itemId    String   @map("template_item_id")
  cycleId   String   @map("cycle_id")           // → AcademicCycle.uuid
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  item  GradingPeriodTemplateItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  cycle AcademicCycle             @relation(fields: [cycleId], references: [uuid], onDelete: Cascade)

  @@unique([itemId, cycleId])
  @@index([cycleId])
  @@map("grading_period_dates")
}

// ── Materias Previas (Secundario — grading-secundario D2) ───────────────────

/// Resolution state for a materia previa.
/// PENDIENTE — debt outstanding.
/// APROBADA  — student cleared the debt (has resolvedGradeCode snapshot).
/// LIBRE     — student took the libre exam path.
enum MateriaPreviaStatus {
  PENDIENTE
  APROBADA
  LIBRE
}

/// Academic-debt record: one row per (student, subject, origin academic year).
/// A Secundario student owes this subject from the year indicated by originAcademicYear.
/// condicion mirrors SubjectFinalGradeCondicion (PREVIA | LIBRE only — REGULAR is never stored here).
model MateriaPrevia {
  id                  String               @id @default(uuid())
  studentId           String               @map("student_id")
  subjectId           String               @map("subject_id")
  /// The academic year the debt originates from (e.g. "2024").
  originAcademicYear  String               @map("origin_academic_year")
  /// Optional provenance link → course_cycles.uuid (the CC where the debt arose). SetNull on CC delete.
  originCourseCycleId String?              @map("origin_course_cycle_id")
  /// How the debt arose: PREVIA or LIBRE. REGULAR is never stored here (domain invariant, D2).
  condicion           SubjectFinalGradeCondicion
  status              MateriaPreviaStatus  @default(PENDIENTE)
  /// Snapshot of the grade code when the debt was resolved/approved.
  resolvedGradeCode   String?              @map("resolved_grade_code")
  resolvedAt          DateTime?            @map("resolved_at")

  student           Student    @relation(fields: [studentId],           references: [id],   onDelete: Cascade)
  subject           Subject    @relation(fields: [subjectId],           references: [id],   onDelete: Cascade)
  originCourseCycle CourseCycle? @relation(fields: [originCourseCycleId], references: [uuid], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@unique([studentId, subjectId, originAcademicYear])
  @@index([studentId])
  @@index([studentId, originAcademicYear])
  @@map("materias_previas")
}

// ── Ingresante (lista de espera de aspirantes) ──────────────

model Ingresante {
  id        String    @id @default(uuid())
  firstName String    @map("first_name")
  lastName  String    @map("last_name")
  dni       String
  email     String?
  birthDate DateTime? @map("birth_date")
  address   String?
  phone     String?
  cycleId   String?   @map("cycle_id")
  cycle     AcademicCycle? @relation(fields: [cycleId], references: [uuid], onDelete: SetNull)
  level     Int
  modality  Int       @default(0)
  status    String    @default("INSCRIPTO")
  active    Boolean   @default(true)
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([dni])
  @@index([status])
  @@index([cycleId])
  @@map("ingresantes")
}

// ── Asistencia Fase 6 ─────────────────────────────────────

// AusenciaXGrupo — subject-level absence per GrupoXCursoXMateriaXCiclo.
// Recorded by the DocenteXCiclo assigned to the group. Independent from AsistenciaDiaria.
// F6-S2
model AusenciaXGrupo {
  id           String   @id @default(uuid())
  grupoId      String   @map("grupo_id")
  studentId    String   @map("student_id")
  date         DateTime @db.Date
  observaciones String? @map("observaciones")

  grupo   GrupoXCursoXMateriaXCiclo @relation(fields: [grupoId],   references: [id], onDelete: Cascade)
  student Student                   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@unique([grupoId, studentId, date])
  @@index([grupoId, date])
  @@index([studentId])
  @@map("ausencias_x_grupo")
}

// AsistenciaDiaria — daily attendance per CourseCycle + date recorded by a preceptor.
// Independent from subject-group absences (asistencia delta spec).
// F6-S3
model AsistenciaDiaria {
  id            String   @id @default(uuid())
  courseCycleId String   @map("course_cycle_id")
  studentId     String   @map("student_id")
  date          DateTime @db.Date
  statusCode    String   @map("status_code")   // e.g. "P" present, "A" absent — free code from AttendanceType.code
  observaciones String?  @map("observaciones")

  courseCycle CourseCycle @relation(fields: [courseCycleId], references: [uuid], onDelete: Cascade)
  student     Student     @relation(fields: [studentId],    references: [id],   onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@unique([courseCycleId, studentId, date])
  @@index([courseCycleId, date])
  @@index([studentId])
  @@map("asistencia_diaria")
}
