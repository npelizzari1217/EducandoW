  materiaId     String @map("materia_id")
  correlativaId String @map("correlativa_id")
  tipo          String                        // "CURSADA"|"FINAL"

  materia     MateriaCarrera @relation("MateriaCorrelativa",         fields: [materiaId],     references: [id], onDelete: Cascade)
  correlativa MateriaCarrera @relation("MateriaCorrelativaRequerida", fields: [correlativaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([materiaId, correlativaId])
  @@index([materiaId])
  @@map("correlatividades")
}

model InscripcionMateria {
