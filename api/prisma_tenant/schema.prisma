  studentId      String  @map("student_id")
  cursoId        String  @map("curso_id")
  subjectId      String  @map("subject_id")
  trimestre      String                       // "1T"|"2T"|"3T"
  nota           Float                        // 1.0..10.0
  condicion      String                       // "APROBADO"|"PREVIA"|"LIBRE"
  notaDiciembre  Float?  @map("nota_diciembre")
  notaFebrero    Float?  @map("nota_febrero")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  curso   Curso   @relation(fields: [cursoId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@unique([studentId, cursoId, subjectId, trimestre])
  @@index([studentId])
  @@index([cursoId])
  @@index([subjectId])
  @@map("calificaciones_secundario")
}

model MesaExamen {
  id          String   @id @default(uuid())
  subjectId   String   @map("subject_id")
  fecha       DateTime
  turno       String                    // "DICIEMBRE"|"FEBRERO"
  presidenteId String  @map("presidente_id")
  active      Boolean  @default(true)
  deletedAt   DateTime? @map("deleted_at")

  subject    Subject               @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  presidente Teacher               @relation(fields: [presidenteId], references: [id], onDelete: Restrict)
  inscripciones MesaExamenInscripcion[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@index([subjectId])
  @@index([fecha])
  @@index([presidenteId])
  @@map("mesas_examen")
}

model MesaExamenInscripcion {
  id             String  @id @default(uuid())
  mesaId         String  @map("mesa_id")
  studentId      String  @map("student_id")
  notaFinal      Float?  @map("nota_final")
  condicionFinal String  @map("condicion_final") // "APROBADO"|"DESAPROBADO"|"AUSENTE"

  mesa    MesaExamen @relation(fields: [mesaId], references: [id], onDelete: Cascade)
  student Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@unique([mesaId, studentId])
  @@index([mesaId])
  @@index([studentId])
  @@map("mesa_examen_inscripciones")
}

model RegimenAcademico {
