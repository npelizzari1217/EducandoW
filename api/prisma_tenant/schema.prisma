generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/@prisma/tenant-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Personnel ──────────────────────────────────────────────
// NOTE: No institutionId — tenant DB is dedicated to one institution

model Student {
  id            String   @id @default(uuid())
  firstName     String
  lastName      String
  dni           String   @unique
  email         String?
  birthDate     DateTime?
  guardianName  String?
  guardianPhone String?
  motherName    String?
  fatherDni     String?
  motherDni     String?
  address       String?
  phone         String?
  photoUrl      String?
  userId        String?

  active    Boolean   @default(true)
  deletedAt DateTime?

  enrollments             Enrollment[]
  notas                   Nota[]
  notasTrimestrales       NotaTrimestral[]
  attendances             Attendance[]
  guardians               StudentGuardian[]
  salaEnrollments         SalaEnrollment[]
  informesEvolutivos      InformeEvolutivo[]
  calificacionesPrimario  CalificacionPrimario[]
  calificacionesSecundario CalificacionSecundario[]
  mesaExamenInscripciones MesaExamenInscripcion[]
  competencyValuations    CompetencyValuation[]
  inscripcionesMateria    InscripcionMateria[]
  actaExamenNotas         ActaExamenNota[]
  titulos                 Titulo[]
  observations            StudentObservation[]
  subjectPeriodGrades     SubjectPeriodGrade[]
  subjectFinalGrades      SubjectFinalGrade[]
  materiasPrevias         MateriaPrevia[]
  alumnosXMateriaXCursoXCiclo AlumnosXMateriaXCursoXCiclo[]
  ausenciasXGrupo             AusenciaXGrupo[]
  asistenciaDiaria            AsistenciaDiaria[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lastName])
  @@index([dni])
  @@map("students")
}

enum GuardianRelationship {
  mother
  father
  legal_guardian
  other
}

model StudentGuardian {
  id                     String               @id @default(uuid())
  studentId              String
  userId                 String
  relationship           GuardianRelationship
  isFinancialResponsible Boolean              @default(false) @map("is_financial_responsible")
  isAuthorizedToPickUp   Boolean              @default(false) @map("is_authorized_to_pick_up")
  createdAt              DateTime             @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, userId])
  @@index([studentId])
  @@index([userId])
  @@map("student_guardians")
}

model Teacher {
  id            String   @id @default(uuid())
  firstName     String
  lastName      String
  dni           String   @unique
  email         String
  phone         String?
  title         String?
  /// Link to master-DB User.id (no FK — cross-DB reference). Stored in column user_id via @map. AD-6.
  userId        String?  @map("user_id")

  active    Boolean   @default(true)
  deletedAt DateTime?

  subjectAssignments   SubjectAssignment[]
  salas                Sala[]
  grados               Grado[]
  cursos               Curso[]
  mesasExamen          MesaExamen[]
  actasExamen          ActaExamen[]
  courseCyclesHomeroom CourseCycle[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lastName])
  @@index([dni])
  @@index([userId])
  @@map("teachers")
}

// ── Asignacion Curso x Ciclo (Fase 4) ─────────────────────

// RolCurso — functional role within a CursoXCiclo.
// PRECEPTOR: daily attendance (presente diario). Multiple per CC allowed (D2).
// TITULAR: homeroom teacher link (migrated from CourseCycle.homeroomTeacherId in Fase 4 backfill).
enum RolCurso {
  PRECEPTOR
  TITULAR
}

// TurnoCurso — shift for a course-cycle assignment.
// Optional and informational — no uniqueness constraint per D2.
enum TurnoCurso {
  MANANA
  TARDE
  VESPERTINO
  NOCHE
}

// AsignacionCursoXCiclo — assignment of a DocenteXCiclo to a CursoXCiclo at the
// course level (Fase 4, ACC-R1/R2). INDEPENDENT from GrupoXCursoXMateriaXCiclo (ACC-R4).
// D2: turno is informational — no uniqueness constraint on it.
// Multiple preceptors per CC are allowed; multiple per turno are allowed.
// TITULAR: at most one per CC enforced at application layer (ACC-S5).
model AsignacionCursoXCiclo {
  id               String     @id @default(uuid())
  courseCycleId    String     @map("course_cycle_id")     // → CourseCycle.uuid
  docenteXCicloId  String     @map("docente_x_ciclo_id")  // → DocenteXCiclo.id
  rol              RolCurso
  turno            TurnoCurso? // optional and informational (D2)

  courseCycle   CourseCycle  @relation(fields: [courseCycleId], references: [uuid], onDelete: Cascade)
  docenteXCiclo DocenteXCiclo @relation(fields: [docenteXCicloId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@unique([courseCycleId, docenteXCicloId, rol, turno])
  @@index([courseCycleId])
  @@index([docenteXCicloId])
  @@map("asignaciones_curso_x_ciclo")
}

// ── Docente x Ciclo (Fase 2) ───────────────────────────────

// DocenteXCiclo — participation record linking a master-DB User to an AcademicCycle.
// Covers both teachers (docentes) and preceptors. Behavioral distinction is
// determined by the User's system modules (DC-R3), not by a type flag here.
// userId: cross-DB reference to master User.id — no FK (AD-6 pattern).
// cycleId: references AcademicCycle.uuid in this tenant DB.
// Persona fields live in master User (DC-R2) — not stored here.
model DocenteXCiclo {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")    // master User.id, no FK — cross-DB (AD-6)
  cycleId   String    @map("cycle_id")  // → AcademicCycle.uuid

  active    Boolean   @default(true)
  deletedAt DateTime? @map("deleted_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")

  cycle AcademicCycle @relation(fields: [cycleId], references: [uuid])

  grupos       GrupoXCursoXMateriaXCiclo[]
  asignaciones AsignacionCursoXCiclo[]

  @@unique([userId, cycleId])
  @@index([cycleId])
  @@index([userId])
  @@map("docentes_x_ciclo")
}

// ── Materia / Grupo por Ciclo (Fase 3a) ───────────────────

// MateriaXCursoXCiclo — one row per (CourseCycle, Subject) after "Generar".
// Materializes the study plan subjects into a specific course-cycle.
// studyPlanSubjectId: provenance link (not a FK — plan lives in tenant but
//   the reference is kept soft so plan edits don't cascade into materias).
model MateriaXCursoXCiclo {
  id                   String  @id @default(uuid())
  courseCycleId        String  @map("course_cycle_id")         // → CourseCycle.uuid
  subjectId            String  @map("subject_id")              // → Subject.id
  studyPlanSubjectId   String? @map("study_plan_subject_id")   // provenance (soft ref)

  courseCycle CourseCycle @relation(fields: [courseCycleId], references: [uuid], onDelete: Restrict)
  subject     Subject     @relation(fields: [subjectId],     references: [id],   onDelete: Restrict)

  alumnos AlumnosXMateriaXCursoXCiclo[]
  grupos  GrupoXCursoXMateriaXCiclo[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@unique([courseCycleId, subjectId])
  @@index([courseCycleId])
  @@map("materias_x_curso_x_ciclo")
}

// AlumnosXMateriaXCursoXCiclo — authoritative universe of students for a subject.
// Students must be added one by one (MGC-R2); bulk endpoint is out of scope.
// The @@unique([materiaXCursoXCicloId, studentId]) enforces 1 row per student-materia.
model AlumnosXMateriaXCursoXCiclo {
  id                    String @id @default(uuid())
  materiaXCursoXCicloId String @map("materia_x_curso_x_ciclo_id")
  studentId             String @map("student_id")                  // → Student.id

  materia MateriaXCursoXCiclo @relation(fields: [materiaXCursoXCicloId], references: [id], onDelete: Cascade)
  student Student              @relation(fields: [studentId],             references: [id], onDelete: Cascade)

  grupoMemberships AlumnosXGrupoXCursoXMateriaXCiclo[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@unique([materiaXCursoXCicloId, studentId], map: "alumnos_x_materia_x_curso_x_ciclo_materia_student_key")
  @@index([materiaXCursoXCicloId])
  @@map("alumnos_x_materia_x_curso_x_ciclo")
}

// GrupoXCursoXMateriaXCiclo — one group per (MateriaXCursoXCiclo, DocenteXCiclo).
// For a normal (non-split) subject: 1 group = all students.
// For a split subject (materia partida): N groups, each with a different DocenteXCiclo.
// Overlap is allowed (co-docencia): same student in multiple groups of the same materia.
model GrupoXCursoXMateriaXCiclo {
  id                    String  @id @default(uuid())
  materiaXCursoXCicloId String  @map("materia_x_curso_x_ciclo_id")
  docenteXCicloId       String  @map("docente_x_ciclo_id")           // → DocenteXCiclo.id
  name                  String?

  materia       MateriaXCursoXCiclo @relation(fields: [materiaXCursoXCicloId], references: [id], onDelete: Cascade)
  docenteXCiclo DocenteXCiclo       @relation(fields: [docenteXCicloId],       references: [id], onDelete: Restrict)

  alumnos    AlumnosXGrupoXCursoXMateriaXCiclo[]
  ausencias  AusenciaXGrupo[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@unique([materiaXCursoXCicloId, docenteXCicloId], map: "grupos_x_curso_x_materia_x_ciclo_materia_docente_key")
  @@index([materiaXCursoXCicloId])
  @@index([docenteXCicloId])
  @@map("grupos_x_curso_x_materia_x_ciclo")
}

// AlumnosXGrupoXCursoXMateriaXCiclo — maps a student (via their materia membership)
// into a specific group. The FK to AlumnosXMateriaXCursoXCiclo (not to Student directly)
// enforces grupo ⊆ materia at the DB level (MGC-R4). Cross-course students are
// impossible because the alumnoMateria row itself belongs to a specific CourseCycle.
model AlumnosXGrupoXCursoXMateriaXCiclo {
  id                          String @id @default(uuid())
  grupoId                     String @map("grupo_id")
  alumnosXMateriaXCursoXCicloId String @map("alumnos_x_materia_x_curso_x_ciclo_id")

  grupo         GrupoXCursoXMateriaXCiclo   @relation(fields: [grupoId],                        references: [id], onDelete: Cascade)
  alumnoMateria AlumnosXMateriaXCursoXCiclo @relation(fields: [alumnosXMateriaXCursoXCicloId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@unique([grupoId, alumnosXMateriaXCursoXCicloId], map: "alumnos_x_grupo_x_materia_x_ciclo_grupo_alumno_key")
  @@index([grupoId])
  @@index([alumnosXMateriaXCursoXCicloId])
  @@map("alumnos_x_grupo_x_curso_x_materia_x_ciclo")
}

// ── Academic Cycles ───────────────────────────────────────

model AcademicCycle {
  id          Int       @id @default(autoincrement())
  uuid        String    @unique @default(uuid())
  code        String    @unique // validated by CycleCode VO: alphanumeric uppercase, 1–15 chars
  name        String
  level       Int
  modality    Int       @default(0)
  startDate   DateTime  @map("start_date")
  endDate     DateTime  @map("end_date")
  active      Boolean   @default(true)
  deletedAt   DateTime?

  firstBimStart  DateTime? @map("first_bim_start")   // @deprecated grading-foundations: reemplazado por GradingPeriodDate
  firstBimEnd    DateTime? @map("first_bim_end")     // @deprecated grading-foundations: reemplazado por GradingPeriodDate
  secondBimStart DateTime? @map("second_bim_start")  // @deprecated grading-foundations: reemplazado por GradingPeriodDate
  secondBimEnd   DateTime? @map("second_bim_end")    // @deprecated grading-foundations: reemplazado por GradingPeriodDate
  thirdBimStart  DateTime? @map("third_bim_start")   // @deprecated grading-foundations: reemplazado por GradingPeriodDate
  thirdBimEnd    DateTime? @map("third_bim_end")     // @deprecated grading-foundations: reemplazado por GradingPeriodDate
  fourthBimStart DateTime? @map("fourth_bim_start")  // @deprecated grading-foundations: reemplazado por GradingPeriodDate
  fourthBimEnd   DateTime? @map("fourth_bim_end")    // @deprecated grading-foundations: reemplazado por GradingPeriodDate

  enrollments         Enrollment[]
  attendances         Attendance[]
  courseCycles        CourseCycle[]
  gradingPeriodDates  GradingPeriodDate[]
  studyPlans          StudyPlan[]         @relation("StudyPlanCycle")
  ingresantes         Ingresante[]
  docentesXCiclo      DocenteXCiclo[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([level])
  @@index([active])
  @@map("academic_cycles")
}

// ── Course Cycle ────────────────────────────────────────────

model CourseCycle {
  id             Int       @id @default(autoincrement())
  uuid           String    @unique @default(uuid())
  courseId       String
  studyPlanId    String
  cycleId        String
  courseName     String
  level          Int
  active         Boolean   @default(true)
  passingGrade   Float
  promotionText  String?
  firstBimStart  DateTime? @map("first_bim_start")   // @deprecated grading-foundations: reemplazado por GradingPeriodDate
  firstBimEnd    DateTime? @map("first_bim_end")     // @deprecated grading-foundations: reemplazado por GradingPeriodDate
  secondBimStart DateTime? @map("second_bim_start")  // @deprecated grading-foundations: reemplazado por GradingPeriodDate
  secondBimEnd   DateTime? @map("second_bim_end")    // @deprecated grading-foundations: reemplazado por GradingPeriodDate
  thirdBimStart  DateTime? @map("third_bim_start")   // @deprecated grading-foundations: reemplazado por GradingPeriodDate
  thirdBimEnd    DateTime? @map("third_bim_end")     // @deprecated grading-foundations: reemplazado por GradingPeriodDate
  fourthBimStart DateTime? @map("fourth_bim_start")  // @deprecated grading-foundations: reemplazado por GradingPeriodDate
  fourthBimEnd   DateTime? @map("fourth_bim_end")    // @deprecated grading-foundations: reemplazado por GradingPeriodDate
  activeGradingPeriod Int? @map("active_grading_period") // @deprecated grading-foundations: reemplazado por GradingPeriodDate
  /// @deprecated — migrado a AsignacionCursoXCiclo rol=TITULAR (Fase 4 backfill). FK → Teacher.id. NOT DROPPED (D5).
  homeroomTeacherId String? @map("homeroom_teacher_id")
  lastModifiedAt DateTime  @updatedAt @map("last_modified_at")
  deletedAt      DateTime?

  course          CourseSection  @relation(fields: [courseId], references: [id])
  studyPlan       StudyPlan      @relation(fields: [studyPlanId], references: [id])
  cycle           AcademicCycle  @relation(fields: [cycleId], references: [uuid])
  homeroomTeacher Teacher?       @relation(fields: [homeroomTeacherId], references: [id], onDelete: SetNull)

  competencyValuations  CompetencyValuation[]
  subjectGradingPeriods SubjectGradingPeriod[]
  subjectPeriodGrades   SubjectPeriodGrade[]
  subjectFinalGrades    SubjectFinalGrade[]
  materiasPrevias       MateriaPrevia[]
  materiasXCiclo        MateriaXCursoXCiclo[]
  asignacionesCurso     AsignacionCursoXCiclo[]
  asistenciaDiaria      AsistenciaDiaria[]

  @@unique([courseId, cycleId])
  @@index([cycleId])
  @@index([studyPlanId])
  @@index([level])
  @@index([homeroomTeacherId])
  @@map("course_cycles")
}

// ── Enrollment ─────────────────────────────────────────────

model Enrollment {
  id           String   @id @default(uuid())
  studentId    String
  cycleId      String?
  level        Int
  modality     Int    @default(0)
  academicYear String
  grade        String?
  division     String?
  status       String   @default("ACTIVE")
  enrolledAt   DateTime @default(now())
  printable    Boolean  @default(true)
  promoted     Boolean  @default(false)

  activeGradingPeriod Int? @map("active_grading_period")

  active    Boolean   @default(true)
  deletedAt DateTime?

  student      Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  cycle        AcademicCycle? @relation(fields: [cycleId], references: [uuid], onDelete: SetNull)
  observations StudentObservation[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([studentId])
  @@index([cycleId])
  @@index([status])
  @@map("enrollments")
}

// ── Pedagogical ────────────────────────────────────────────

model Subject {
  id    String @id @default(uuid())
  name  String
  level Int
  modality Int    @default(0)

  active    Boolean   @default(true)
  deletedAt DateTime?

  subjectAssignments       SubjectAssignment[]
  attendances              Attendance[]
  studyPlanSubjects        StudyPlanSubject[]
  calificacionesPrimario   CalificacionPrimario[]
  calificacionesSecundario CalificacionSecundario[]
  mesasExamen              MesaExamen[]
  regimenAcademico         RegimenAcademico[]
  materiasCarrera          MateriaCarrera[]
  subjectGradingPeriods    SubjectGradingPeriod[]
  subjectPeriodGrades      SubjectPeriodGrade[]
  subjectFinalGrades       SubjectFinalGrade[]
  materiasPrevias          MateriaPrevia[]
  materiasXCursoXCiclo     MateriaXCursoXCiclo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([level])
  @@map("subjects")
}

model CourseSection {
  id           String @id @default(uuid())
  name         String
  grade        String?
  division     String?
  level        Int
  modality     Int    @default(0)
  academicYear String

  active    Boolean   @default(true)
  deletedAt DateTime?

  attendances        Attendance[]
  subjectAssignments SubjectAssignment[]
  studyPlanCourses   StudyPlanCourse[]
  grados             Grado[]
  cursos             Curso[]
  courseCycles       CourseCycle[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([level])
  @@index([academicYear])
  @@map("course_sections")
}

model SubjectAssignment {
  id              String @id @default(uuid())
  subjectId       String
  teacherId       String
  courseSectionId String

  active    Boolean   @default(true)
  deletedAt DateTime?

  subject       Subject       @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher       Teacher       @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  courseSection CourseSection @relation(fields: [courseSectionId], references: [id], onDelete: Cascade)

  evaluaciones      Evaluacion[]
  notasTrimestrales NotaTrimestral[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([subjectId])
  @@index([teacherId])
  @@index([courseSectionId])
  @@map("subject_assignments")
}

// ── Subject Competencies ──────────────────────────────────

model SubjectCompetency {
  id                   String   @id @default(uuid())
  studyPlanSubjectId   String
  name                 String
  active               Boolean  @default(true)
  deletedAt            DateTime?

  studyPlanSubject StudyPlanSubject @relation(fields: [studyPlanSubjectId], references: [id], onDelete: Cascade)

  valuations CompetencyValuation[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([studyPlanSubjectId, name])
  @@index([studyPlanSubjectId])
  @@map("subject_competencies")
}

model CompetencyValuation {
  id            String   @id @default(uuid())
  competencyId  String
  studentId     String
  courseCycleId String   @map("course_cycle_id")
  active        Boolean  @default(true)
  deletedAt     DateTime?

  competency  SubjectCompetency @relation(fields: [competencyId], references: [id], onDelete: Cascade)
  student     Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  courseCycle CourseCycle       @relation(fields: [courseCycleId], references: [uuid], onDelete: Restrict)

  periodValuations CompetencyPeriodValuation[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([studentId, competencyId, courseCycleId])
  @@index([competencyId])
  @@index([studentId])
  @@index([courseCycleId])
  @@map("competency_valuations")
}

model CompetencyPeriodValuation {
  id               String              @id @default(uuid())
  valuationId      String              @map("valuation_id")
  periodItemId     String              @map("period_item_id")
  gradeScaleValueId String?            @map("grade_scale_value_id")
  gradeCode        String?             @map("grade_code")
  internalStatus   GradeInternalStatus? @map("internal_status")
  modificable      Boolean             @default(true)
  imprimible       Boolean             @default(false)

  valuation   CompetencyValuation       @relation(fields: [valuationId], references: [id], onDelete: Cascade)
  periodItem  GradingPeriodTemplateItem @relation(fields: [periodItemId], references: [id], onDelete: Restrict)
  gradeValue  GradeScaleValue?          @relation(fields: [gradeScaleValueId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([valuationId, periodItemId])
  @@index([valuationId])
  @@index([periodItemId])
  @@map("competency_period_valuations")
}

// ── Grade Scales ─────────────────────────────────────────

enum GradeInternalStatus {
  APROBADO
  NO_APROBADO
  EN_PROCESO
  LIBRE
}

model GradeScale {
  id        String   @id @default(uuid())
  name      String              // "Cualitativa", "Numérica 1-10"
  level     Int                 // EducationalLevelCode (1-4)
  modality  Int    @default(0)  // EducationalModalityCode (0-2)
  active    Boolean @default(true)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  values GradeScaleValue[]

  @@index([level])
  @@unique([level, modality, name])
  @@map("grade_scales")
}
// ELIMINADOS: minValue, maxValue, isConceptual — grading-foundations

model GradeScaleValue {
  id             String              @id @default(uuid())
  scaleId        String              // FK → GradeScale
  code           String              // alfanumérico libre: "10", "A+", "Logrado"
  label          String              // "Muy Bueno"
  internalStatus GradeInternalStatus // reemplaza isApproved bool
  sortOrder      Int    @default(0)  // orden de display
  active         Boolean @default(true)
  deletedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  scale GradeScale @relation(fields: [scaleId], references: [id], onDelete: Cascade)
  notas Nota[]
  competencyPeriodValuations CompetencyPeriodValuation[]
  subjectPeriodGrades        SubjectPeriodGrade[]
  subjectFinalGrades         SubjectFinalGrade[]

  @@index([scaleId])
  @@unique([scaleId, code])
  @@map("grade_scale_values")
}
// ELIMINADOS: isApproved (→ internalStatus), numericValue — grading-foundations

// ── Evaluation ───────────────────────────────────────────

model Evaluacion {
  id              String   @id @default(uuid())
  assignmentId    String
  title           String
  description     String?
  evaluationDate  DateTime
  weight          Float    @default(1)
  active          Boolean  @default(true)
  deletedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  assignment SubjectAssignment @relation(fields: [assignmentId], references: [id])
  notas      Nota[]

  @@index([assignmentId])
  @@index([evaluationDate])
  @@map("evaluaciones")
}

model Nota {
  id               String   @id @default(uuid())
  evaluationId     String
  studentId        String
  numericValue     Float?
  qualitativeValue String?
  comments         String?
  registeredAt     DateTime @default(now())
  active           Boolean  @default(true)
  deletedAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // FK to the grade scale value (for current reference)
  gradeScaleValueId String?
  gradeScaleValue   GradeScaleValue? @relation(fields: [gradeScaleValueId], references: [id])

  // SNAPSHOT — immutable historical record
  gradeCode  String?   // "10", "DESTACADO" — the code at time of grading
  gradeLabel String?   // "Excelente (10)" — the label at time of grading
  isApproved Boolean?  // true/false — approval status at time of grading

  evaluation Evaluacion @relation(fields: [evaluationId], references: [id])
  student    Student    @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([evaluationId])
  @@index([registeredAt])
  @@unique([evaluationId, studentId])
  @@map("notas")
}

model PeriodoEvaluacion {
  id           String   @id @default(uuid())
  academicYear String
  name         String
  startDate    DateTime
  endDate      DateTime
  active       Boolean  @default(true)
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  notasTrimestrales NotaTrimestral[]

  @@index([academicYear])
  @@map("periodos_evaluacion")
}

model NotaTrimestral {
  id             String  @id @default(uuid())
  studentId      String
  assignmentId   String
  periodId       String
  finalGrade     Float
  attendancePct  Float?
  active         Boolean @default(true)
  deletedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  student    Student           @relation(fields: [studentId], references: [id])
  assignment SubjectAssignment @relation(fields: [assignmentId], references: [id])
  period     PeriodoEvaluacion @relation(fields: [periodId], references: [id])

  @@index([studentId])
  @@index([periodId])
  @@unique([studentId, assignmentId, periodId])
  @@map("notas_trimestrales")
}

model AttendanceType {
  id           String    @id @default(uuid())
  level        Int                                       // EducationalLevelCode (1..4)
  code         String                                    // ≤ 4 chars, mayúsculas: "P","SAB","DOM","X"
  description  String
  absenceValue Decimal   @default(0) @db.Decimal(4, 2)  // soporta 0, 0.5, 1, 1.5
  isPresent    Boolean   @default(true)
  assignable   Boolean   @default(true)                  // ¿seleccionable en la grilla diaria?
  isSystem     Boolean   @default(false)                 // protegido: no editar/borrar
  active       Boolean   @default(true)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  attendances Attendance[]

  @@unique([level, code])
  @@index([level])
  @@map("attendance_types")
}

model Attendance {
  id              String   @id @default(uuid())
  studentId       String
  courseSectionId String
  subjectId       String?
  cycleId         String?
  date            DateTime
  statusId        String
  note            String?

  active    Boolean   @default(true)
  deletedAt DateTime?

  // SNAPSHOT — immutable historical record
  statusCode        String?   // "PRESENT", "ABSENT" — code at time of recording
  statusDescription String?   // "Presente", "Ausente" — description at time
  absenceValue      Float?    // 0, 0.5, 1 — value at time of recording
  isPresent         Boolean?  // true/false — present flag at time

  student       Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  courseSection CourseSection  @relation(fields: [courseSectionId], references: [id])
  subject       Subject?       @relation(fields: [subjectId], references: [id])
  cycle         AcademicCycle? @relation(fields: [cycleId], references: [uuid], onDelete: SetNull)
  status        AttendanceType @relation(fields: [statusId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([studentId])
  @@index([courseSectionId])
  @@index([date])
  @@index([cycleId])
  @@unique([studentId, courseSectionId, subjectId, date])
  @@map("attendances")
}

// ── Study Plans ───────────────────────────────────────────

model StudyPlan {
  id        String    @id @default(uuid())
  name      String
  level     Int
  modality  Int       @default(0)
  cycleId   String?   @map("cycle_id")
  active    Boolean   @default(true)
  deletedAt DateTime?

  courses      StudyPlanCourse[]
  courseCycles CourseCycle[]
  cycle        AcademicCycle?    @relation("StudyPlanCycle", fields: [cycleId], references: [uuid], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([level])
  @@index([cycleId])
  @@map("study_plans")
}

model StudyPlanCourse {
  id              String @id @default(uuid())
  studyPlanId     String
  courseSectionId String

  studyPlan     StudyPlan     @relation(fields: [studyPlanId], references: [id], onDelete: Cascade)
  courseSection CourseSection @relation(fields: [courseSectionId], references: [id], onDelete: Cascade)

  subjects StudyPlanSubject[]

  @@unique([studyPlanId, courseSectionId])
  @@index([studyPlanId])
  @@map("study_plan_courses")
}

model StudyPlanSubject {
  id                String  @id @default(uuid())
  studyPlanCourseId String
  subjectId         String
  hoursPerWeek      Int?

  studyPlanCourse StudyPlanCourse @relation(fields: [studyPlanCourseId], references: [id], onDelete: Cascade)
  subject         Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  competencies SubjectCompetency[]

  @@unique([studyPlanCourseId, subjectId])
  @@index([studyPlanCourseId])
