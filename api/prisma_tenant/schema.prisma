generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/@prisma/tenant-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Personnel ──────────────────────────────────────────────
// NOTE: No institutionId — tenant DB is dedicated to one institution

model Student {
  id            String   @id @default(uuid())
  firstName     String
  lastName      String
  dni           String   @unique
  email         String?
  birthDate     DateTime?
  guardianName  String?
  guardianPhone String?
  motherName    String?
  fatherDni     String?
  motherDni     String?
  address       String?
  phone         String?
  photoUrl      String?
  userId        String?

  active    Boolean   @default(true)
  deletedAt DateTime?

  enrollments             Enrollment[]
  notas                   Nota[]
  notasTrimestrales       NotaTrimestral[]
  attendances             Attendance[]
  guardians               StudentGuardian[]
  salaEnrollments         SalaEnrollment[]
  informesEvolutivos      InformeEvolutivo[]
  calificacionesPrimario  CalificacionPrimario[]
  calificacionesSecundario CalificacionSecundario[]
  mesaExamenInscripciones MesaExamenInscripcion[]
  competencyValuations    CompetencyValuation[]
  inscripcionesMateria    InscripcionMateria[]
  actaExamenNotas         ActaExamenNota[]
  titulos                 Titulo[]
  observations            StudentObservation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lastName])
  @@index([dni])
  @@map("students")
}

enum GuardianRelationship {
  mother
  father
  legal_guardian
  other
}

model StudentGuardian {
  id                     String               @id @default(uuid())
  studentId              String
  userId                 String
  relationship           GuardianRelationship
  isFinancialResponsible Boolean              @default(false) @map("is_financial_responsible")
  isAuthorizedToPickUp   Boolean              @default(false) @map("is_authorized_to_pick_up")
  createdAt              DateTime             @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, userId])
  @@index([studentId])
  @@index([userId])
  @@map("student_guardians")
}

model Teacher {
  id            String   @id @default(uuid())
  firstName     String
  lastName      String
  dni           String   @unique
  email         String
  phone         String?
  title         String?

  active    Boolean   @default(true)
  deletedAt DateTime?

  subjectAssignments SubjectAssignment[]
  salas              Sala[]
  grados             Grado[]
  cursos             Curso[]
  mesasExamen        MesaExamen[]
  actasExamen        ActaExamen[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lastName])
  @@index([dni])
  @@map("teachers")
}

// ── Academic Cycles ───────────────────────────────────────

model AcademicCycle {
  id          Int       @id @default(autoincrement())
  uuid        String    @unique @default(uuid())
  code        String    @unique // validated by CycleCode VO: alphanumeric uppercase, 1–15 chars
  name        String
  level       Int
  modality    Int       @default(0)
  startDate   DateTime  @map("start_date")
  endDate     DateTime  @map("end_date")
  active      Boolean   @default(true)
  deletedAt   DateTime?

  firstBimStart  DateTime? @map("first_bim_start")   // @deprecated grading-foundations: reemplazado por GradingPeriodDate
  firstBimEnd    DateTime? @map("first_bim_end")     // @deprecated grading-foundations: reemplazado por GradingPeriodDate
  secondBimStart DateTime? @map("second_bim_start")  // @deprecated grading-foundations: reemplazado por GradingPeriodDate
  secondBimEnd   DateTime? @map("second_bim_end")    // @deprecated grading-foundations: reemplazado por GradingPeriodDate
  thirdBimStart  DateTime? @map("third_bim_start")   // @deprecated grading-foundations: reemplazado por GradingPeriodDate
  thirdBimEnd    DateTime? @map("third_bim_end")     // @deprecated grading-foundations: reemplazado por GradingPeriodDate
  fourthBimStart DateTime? @map("fourth_bim_start")  // @deprecated grading-foundations: reemplazado por GradingPeriodDate
  fourthBimEnd   DateTime? @map("fourth_bim_end")    // @deprecated grading-foundations: reemplazado por GradingPeriodDate

  enrollments         Enrollment[]
  attendances         Attendance[]
  courseCycles        CourseCycle[]
  gradingPeriodDates  GradingPeriodDate[]
  studyPlans          StudyPlan[]         @relation("StudyPlanCycle")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([level])
  @@index([active])
  @@map("academic_cycles")
}

// ── Course Cycle ────────────────────────────────────────────

model CourseCycle {
  id             Int       @id @default(autoincrement())
  uuid           String    @unique @default(uuid())
  courseId       String
  studyPlanId    String
  cycleId        String
  courseName     String
  level          Int
  active         Boolean   @default(true)
  passingGrade   Float
  promotionText  String?
  firstBimStart  DateTime? @map("first_bim_start")   // @deprecated grading-foundations: reemplazado por GradingPeriodDate
  firstBimEnd    DateTime? @map("first_bim_end")     // @deprecated grading-foundations: reemplazado por GradingPeriodDate
  secondBimStart DateTime? @map("second_bim_start")  // @deprecated grading-foundations: reemplazado por GradingPeriodDate
  secondBimEnd   DateTime? @map("second_bim_end")    // @deprecated grading-foundations: reemplazado por GradingPeriodDate
  thirdBimStart  DateTime? @map("third_bim_start")   // @deprecated grading-foundations: reemplazado por GradingPeriodDate
  thirdBimEnd    DateTime? @map("third_bim_end")     // @deprecated grading-foundations: reemplazado por GradingPeriodDate
  fourthBimStart DateTime? @map("fourth_bim_start")  // @deprecated grading-foundations: reemplazado por GradingPeriodDate
  fourthBimEnd   DateTime? @map("fourth_bim_end")    // @deprecated grading-foundations: reemplazado por GradingPeriodDate
  activeGradingPeriod Int? @map("active_grading_period") // @deprecated grading-foundations: reemplazado por GradingPeriodDate
  lastModifiedAt DateTime  @updatedAt @map("last_modified_at")
  deletedAt      DateTime?

  course    CourseSection  @relation(fields: [courseId], references: [id])
  studyPlan StudyPlan      @relation(fields: [studyPlanId], references: [id])
  cycle     AcademicCycle   @relation(fields: [cycleId], references: [uuid])

  competencyValuations CompetencyValuation[]

  @@unique([courseId, cycleId])
  @@index([cycleId])
  @@index([studyPlanId])
  @@index([level])
  @@map("course_cycles")
}

// ── Enrollment ─────────────────────────────────────────────

model Enrollment {
  id           String   @id @default(uuid())
  studentId    String
  cycleId      String?
  level        Int
  modality     Int    @default(0)
  academicYear String
  grade        String?
  division     String?
  status       String   @default("ACTIVE")
  enrolledAt   DateTime @default(now())
  printable    Boolean  @default(true)
  promoted     Boolean  @default(false)

  activeGradingPeriod Int? @map("active_grading_period")

  active    Boolean   @default(true)
  deletedAt DateTime?

  student Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  cycle   AcademicCycle? @relation(fields: [cycleId], references: [uuid], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([studentId])
  @@index([cycleId])
  @@index([status])
  @@map("enrollments")
}

// ── Pedagogical ────────────────────────────────────────────

model Subject {
  id    String @id @default(uuid())
  name  String
  level Int
  modality Int    @default(0)

  active    Boolean   @default(true)
  deletedAt DateTime?

  subjectAssignments       SubjectAssignment[]
  attendances              Attendance[]
  studyPlanSubjects        StudyPlanSubject[]
  calificacionesPrimario   CalificacionPrimario[]
  calificacionesSecundario CalificacionSecundario[]
  mesasExamen              MesaExamen[]
  regimenAcademico         RegimenAcademico[]
  materiasCarrera          MateriaCarrera[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([level])
  @@map("subjects")
}

model CourseSection {
  id           String @id @default(uuid())
  name         String
  grade        String?
  division     String?
  level        Int
  modality     Int    @default(0)
  academicYear String

  active    Boolean   @default(true)
  deletedAt DateTime?

  attendances        Attendance[]
  subjectAssignments SubjectAssignment[]
  studyPlanCourses   StudyPlanCourse[]
  grados             Grado[]
  cursos             Curso[]
  courseCycles       CourseCycle[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([level])
  @@index([academicYear])
  @@map("course_sections")
}

model SubjectAssignment {
  id              String @id @default(uuid())
  subjectId       String
  teacherId       String
  courseSectionId String

  active    Boolean   @default(true)
  deletedAt DateTime?

  subject       Subject       @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher       Teacher       @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  courseSection CourseSection @relation(fields: [courseSectionId], references: [id], onDelete: Cascade)

  evaluaciones      Evaluacion[]
  notasTrimestrales NotaTrimestral[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([subjectId])
  @@index([teacherId])
  @@index([courseSectionId])
  @@map("subject_assignments")
}

// ── Subject Competencies ──────────────────────────────────

model SubjectCompetency {
  id                   String   @id @default(uuid())
  studyPlanSubjectId   String
  name                 String
  active               Boolean  @default(true)
  deletedAt            DateTime?

  studyPlanSubject StudyPlanSubject @relation(fields: [studyPlanSubjectId], references: [id], onDelete: Cascade)

  valuations CompetencyValuation[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([studyPlanSubjectId, name])
  @@index([studyPlanSubjectId])
  @@map("subject_competencies")
}

model CompetencyValuation {
  id            String   @id @default(uuid())
  competencyId  String
  studentId     String
  courseCycleId String   @map("course_cycle_id")
  active        Boolean  @default(true)
  deletedAt     DateTime?

  competency  SubjectCompetency @relation(fields: [competencyId], references: [id], onDelete: Cascade)
  student     Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  courseCycle CourseCycle       @relation(fields: [courseCycleId], references: [uuid], onDelete: Restrict)

  periodValuations CompetencyPeriodValuation[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([studentId, competencyId, courseCycleId])
  @@index([competencyId])
  @@index([studentId])
  @@index([courseCycleId])
  @@map("competency_valuations")
}

model CompetencyPeriodValuation {
  id               String              @id @default(uuid())
  valuationId      String              @map("valuation_id")
  periodItemId     String              @map("period_item_id")
  gradeScaleValueId String?            @map("grade_scale_value_id")
  gradeCode        String?             @map("grade_code")
  internalStatus   GradeInternalStatus? @map("internal_status")
  modificable      Boolean             @default(true)
  imprimible       Boolean             @default(false)

  valuation   CompetencyValuation       @relation(fields: [valuationId], references: [id], onDelete: Cascade)
  periodItem  GradingPeriodTemplateItem @relation(fields: [periodItemId], references: [id], onDelete: Restrict)
  gradeValue  GradeScaleValue?          @relation(fields: [gradeScaleValueId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([valuationId, periodItemId])
  @@index([valuationId])
  @@index([periodItemId])
  @@map("competency_period_valuations")
}

// ── Grade Scales ─────────────────────────────────────────

enum GradeInternalStatus {
  APROBADO
  NO_APROBADO
  EN_PROCESO
  LIBRE
}

model GradeScale {
  id        String   @id @default(uuid())
  name      String              // "Cualitativa", "Numérica 1-10"
  level     Int                 // EducationalLevelCode (1-4)
  modality  Int    @default(0)  // EducationalModalityCode (0-2)
  active    Boolean @default(true)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  values GradeScaleValue[]

  @@index([level])
  @@unique([level, modality, name])
  @@map("grade_scales")
}
// ELIMINADOS: minValue, maxValue, isConceptual — grading-foundations

model GradeScaleValue {
  id             String              @id @default(uuid())
  scaleId        String              // FK → GradeScale
  code           String              // alfanumérico libre: "10", "A+", "Logrado"
  label          String              // "Muy Bueno"
  internalStatus GradeInternalStatus // reemplaza isApproved bool
  sortOrder      Int    @default(0)  // orden de display
  active         Boolean @default(true)
  deletedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  scale GradeScale @relation(fields: [scaleId], references: [id], onDelete: Cascade)
  notas Nota[]
  competencyPeriodValuations CompetencyPeriodValuation[]

  @@index([scaleId])
  @@unique([scaleId, code])
  @@map("grade_scale_values")
}
// ELIMINADOS: isApproved (→ internalStatus), numericValue — grading-foundations

// ── Evaluation ───────────────────────────────────────────

model Evaluacion {
  id              String   @id @default(uuid())
  assignmentId    String
  title           String
  description     String?
  evaluationDate  DateTime
  weight          Float    @default(1)
  active          Boolean  @default(true)
  deletedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  assignment SubjectAssignment @relation(fields: [assignmentId], references: [id])
  notas      Nota[]

  @@index([assignmentId])
  @@index([evaluationDate])
  @@map("evaluaciones")
}

model Nota {
  id               String   @id @default(uuid())
  evaluationId     String
  studentId        String
  numericValue     Float?
  qualitativeValue String?
  comments         String?
  registeredAt     DateTime @default(now())
  active           Boolean  @default(true)
  deletedAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // FK to the grade scale value (for current reference)
  gradeScaleValueId String?
  gradeScaleValue   GradeScaleValue? @relation(fields: [gradeScaleValueId], references: [id])

  // SNAPSHOT — immutable historical record
  gradeCode  String?   // "10", "DESTACADO" — the code at time of grading
  gradeLabel String?   // "Excelente (10)" — the label at time of grading
  isApproved Boolean?  // true/false — approval status at time of grading

  evaluation Evaluacion @relation(fields: [evaluationId], references: [id])
  student    Student    @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([evaluationId])
  @@index([registeredAt])
  @@unique([evaluationId, studentId])
  @@map("notas")
}

model PeriodoEvaluacion {
  id           String   @id @default(uuid())
  academicYear String
  name         String
  startDate    DateTime
  endDate      DateTime
  active       Boolean  @default(true)
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  notasTrimestrales NotaTrimestral[]

  @@index([academicYear])
  @@map("periodos_evaluacion")
}

model NotaTrimestral {
  id             String  @id @default(uuid())
  studentId      String
  assignmentId   String
  periodId       String
  finalGrade     Float
  attendancePct  Float?
  active         Boolean @default(true)
  deletedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  student    Student           @relation(fields: [studentId], references: [id])
  assignment SubjectAssignment @relation(fields: [assignmentId], references: [id])
  period     PeriodoEvaluacion @relation(fields: [periodId], references: [id])

  @@index([studentId])
  @@index([periodId])
  @@unique([studentId, assignmentId, periodId])
  @@map("notas_trimestrales")
}

model AttendanceType {
  id           String    @id @default(uuid())
  level        Int                                       // EducationalLevelCode (1..4)
  code         String                                    // ≤ 4 chars, mayúsculas: "P","SAB","DOM","X"
  description  String
  absenceValue Decimal   @default(0) @db.Decimal(4, 2)  // soporta 0, 0.5, 1, 1.5
  isPresent    Boolean   @default(true)
  assignable   Boolean   @default(true)                  // ¿seleccionable en la grilla diaria?
  isSystem     Boolean   @default(false)                 // protegido: no editar/borrar
  active       Boolean   @default(true)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  attendances Attendance[]

  @@unique([level, code])
  @@index([level])
  @@map("attendance_types")
}

model Attendance {
  id              String   @id @default(uuid())
  studentId       String
  courseSectionId String
  subjectId       String?
  cycleId         String?
  date            DateTime
  statusId        String
  note            String?

  active    Boolean   @default(true)
  deletedAt DateTime?

  // SNAPSHOT — immutable historical record
  statusCode        String?   // "PRESENT", "ABSENT" — code at time of recording
  statusDescription String?   // "Presente", "Ausente" — description at time
  absenceValue      Float?    // 0, 0.5, 1 — value at time of recording
  isPresent         Boolean?  // true/false — present flag at time

  student       Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  courseSection CourseSection  @relation(fields: [courseSectionId], references: [id])
  subject       Subject?       @relation(fields: [subjectId], references: [id])
  cycle         AcademicCycle? @relation(fields: [cycleId], references: [uuid], onDelete: SetNull)
  status        AttendanceType @relation(fields: [statusId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([studentId])
  @@index([courseSectionId])
  @@index([date])
  @@index([cycleId])
  @@unique([studentId, courseSectionId, subjectId, date])
  @@map("attendances")
}

// ── Study Plans ───────────────────────────────────────────

model StudyPlan {
  id        String    @id @default(uuid())
  name      String
  level     Int
  modality  Int       @default(0)
  cycleId   String?   @map("cycle_id")
  active    Boolean   @default(true)
  deletedAt DateTime?

  courses      StudyPlanCourse[]
  courseCycles CourseCycle[]
  cycle        AcademicCycle?    @relation("StudyPlanCycle", fields: [cycleId], references: [uuid], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([level])
  @@index([cycleId])
  @@map("study_plans")
}

model StudyPlanCourse {
  id              String @id @default(uuid())
  studyPlanId     String
  courseSectionId String

  studyPlan     StudyPlan     @relation(fields: [studyPlanId], references: [id], onDelete: Cascade)
  courseSection CourseSection @relation(fields: [courseSectionId], references: [id], onDelete: Cascade)

  subjects StudyPlanSubject[]

  @@unique([studyPlanId, courseSectionId])
  @@index([studyPlanId])
  @@map("study_plan_courses")
}

model StudyPlanSubject {
  id                String  @id @default(uuid())
  studyPlanCourseId String
  subjectId         String
  hoursPerWeek      Int?

  studyPlanCourse StudyPlanCourse @relation(fields: [studyPlanCourseId], references: [id], onDelete: Cascade)
  subject         Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  competencies SubjectCompetency[]

  @@unique([studyPlanCourseId, subjectId])
  @@index([studyPlanCourseId])
  @@map("study_plan_subjects")
}

// ── Inicial ────────────────────────────────────────────────

model Sala {
  id           String   @id @default(uuid())
  name         String
  ageGroup     Int                    @map("age_group")   // 3, 4 o 5
  turno        String                 @map("turno")       // "MAÑANA" | "TARDE"
  capacity     Int
  teacherId    String?                @map("teacher_id")
  academicYear String                 @map("academic_year")
  active       Boolean  @default(true)
  deletedAt    DateTime?              @map("deleted_at")

  teacher     Teacher?         @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  enrollments SalaEnrollment[]
  informes    InformeEvolutivo[]
  planificaciones Planificacion[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@index([academicYear])
  @@index([ageGroup])
  @@index([teacherId])
  @@map("salas")
}

model SalaEnrollment {
  id           String   @id @default(uuid())
  studentId    String   @map("student_id")
  salaId       String   @map("sala_id")
  academicYear String   @map("academic_year")
  enrolledAt   DateTime @default(now()) @map("enrolled_at")
  active       Boolean  @default(true)
  deletedAt    DateTime? @map("deleted_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  sala    Sala    @relation(fields: [salaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@unique([studentId, salaId, academicYear])
  @@index([studentId])
  @@index([salaId])
  @@map("sala_enrollments")
}

model InformeEvolutivo {
  id                    String   @id @default(uuid())
  studentId             String   @map("student_id")
  salaId                String   @map("sala_id")
  periodo               String                      // "1T" | "2T" | "3T" // @deprecated grading-foundations: reemplazado por GradingPeriodDate
  fecha                 DateTime
  observacionesGenerales String? @map("observaciones_generales")
  active                Boolean  @default(true)
  deletedAt             DateTime? @map("deleted_at")

  student Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  sala    Sala           @relation(fields: [salaId], references: [id], onDelete: Cascade)
  areas   AreaDesarrollo[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@index([studentId])
  @@index([salaId])
  @@index([periodo])
  @@map("informes_evolutivos")
}

model AreaDesarrollo {
  id         String @id @default(uuid())
  informeId  String @map("informe_id")
  area       String                    // "SOCIO_AFECTIVA"|"MOTRIZ"|"COGNITIVA"|"LENGUAJE"|"CREATIVA"
  observacion String
  valoracion String                    // "DESTACADO"|"LOGRADO"|"EN_PROCESO"|"NO_LOGRADO"

  informe InformeEvolutivo @relation(fields: [informeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@index([informeId])
  @@map("areas_desarrollo")
}

model Planificacion {
  id           String   @id @default(uuid())
  salaId       String   @map("sala_id")
  semana       Int                      // 1..40
  academicYear String   @map("academic_year")
  active       Boolean  @default(true)
  deletedAt    DateTime? @map("deleted_at")

  sala        Sala                @relation(fields: [salaId], references: [id], onDelete: Cascade)
  secuencias  SecuenciaDidactica[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@index([salaId])
  @@index([academicYear])
  @@map("planificaciones")
}

model SecuenciaDidactica {
  id              String   @id @default(uuid())
  planificacionId String   @map("planificacion_id")
  nombre          String
  area            String
  actividades     String[]
  recursos        String[]

  planificacion Planificacion @relation(fields: [planificacionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@index([planificacionId])
  @@map("secuencias_didacticas")
}

// ── Primario ───────────────────────────────────────────────

model Grado {
  id              String   @id @default(uuid())
  courseSectionId String?  @map("course_section_id")
  grade           Int                              // 1..6
  division        String                           // "A"|"B"|"C"
  teacherId       String?  @map("teacher_id")
  academicYear    String   @map("academic_year")
  active          Boolean  @default(true)
  deletedAt       DateTime? @map("deleted_at")

  courseSection CourseSection?        @relation(fields: [courseSectionId], references: [id], onDelete: SetNull)
  teacher       Teacher?              @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  calificaciones CalificacionPrimario[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@index([academicYear])
  @@index([teacherId])
  @@index([courseSectionId])
  @@map("grados")
}

model CalificacionPrimario {
  id        String  @id @default(uuid())
  studentId String  @map("student_id")
  gradoId   String  @map("grado_id")
  subjectId String  @map("subject_id")
  trimestre String                    // "1T"|"2T"|"3T"
  nota      Float                     // 1.0..10.0
  concepto  String                    // "EXCELENTE"|"MUY_BUENO"|"BUENO"|"REGULAR"|"INSUFICIENTE"
  aprobado  Boolean

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  grado   Grado   @relation(fields: [gradoId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@unique([studentId, gradoId, subjectId, trimestre])
  @@index([studentId])
  @@index([gradoId])
  @@index([subjectId])
  @@map("calificaciones_primario")
}

// ── Secundario ─────────────────────────────────────────────

model Curso {
  id              String   @id @default(uuid())
  courseSectionId String?  @map("course_section_id")
  year            Int                              // 1..6
  division        String                           // "A"|"B"|"C"
  orientacion     String?                          // "NATURALES"|"SOCIALES"|"ECONOMIA"|"ARTE"
  academicYear    String   @map("academic_year")
  active          Boolean  @default(true)
  deletedAt       DateTime? @map("deleted_at")

  courseSection    CourseSection?           @relation(fields: [courseSectionId], references: [id], onDelete: SetNull)
  teacher          Teacher?                 @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  teacherId        String?                  @map("teacher_id")
  calificaciones   CalificacionSecundario[]
  regimenAcademico RegimenAcademico[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@index([academicYear])
  @@index([courseSectionId])
  @@map("cursos")
}

model CalificacionSecundario {
  id             String  @id @default(uuid())
  studentId      String  @map("student_id")
  cursoId        String  @map("curso_id")
  subjectId      String  @map("subject_id")
  trimestre      String                       // "1T"|"2T"|"3T"
  nota           Float                        // 1.0..10.0
  condicion      String                       // "APROBADO"|"PREVIA"|"LIBRE"
  notaDiciembre  Float?  @map("nota_diciembre")
  notaFebrero    Float?  @map("nota_febrero")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  curso   Curso   @relation(fields: [cursoId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@unique([studentId, cursoId, subjectId, trimestre])
  @@index([studentId])
  @@index([cursoId])
  @@index([subjectId])
  @@map("calificaciones_secundario")
}

model MesaExamen {
  id          String   @id @default(uuid())
  subjectId   String   @map("subject_id")
  fecha       DateTime
  turno       String                    // "DICIEMBRE"|"FEBRERO"
  presidenteId String  @map("presidente_id")
  active      Boolean  @default(true)
  deletedAt   DateTime? @map("deleted_at")

  subject    Subject               @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  presidente Teacher               @relation(fields: [presidenteId], references: [id], onDelete: Restrict)
  inscripciones MesaExamenInscripcion[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@index([subjectId])
  @@index([fecha])
  @@index([presidenteId])
  @@map("mesas_examen")
}

model MesaExamenInscripcion {
  id             String  @id @default(uuid())
  mesaId         String  @map("mesa_id")
  studentId      String  @map("student_id")
  notaFinal      Float?  @map("nota_final")
  condicionFinal String  @map("condicion_final") // "APROBADO"|"DESAPROBADO"|"AUSENTE"

  mesa    MesaExamen @relation(fields: [mesaId], references: [id], onDelete: Cascade)
  student Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@unique([mesaId, studentId])
  @@index([mesaId])
  @@index([studentId])
  @@map("mesa_examen_inscripciones")
}

model RegimenAcademico {
  id                     String  @id @default(uuid())
  cursoId                String  @map("curso_id")
  subjectId              String  @map("subject_id")
  promocionDirecta       Boolean @map("promocion_directa")
  requiereExamenFinal    Boolean @map("requiere_examen_final")
  notaMinimaAprobacion   Float   @default(6) @map("nota_minima_aprobacion")

  curso   Curso   @relation(fields: [cursoId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@unique([cursoId, subjectId])
  @@index([cursoId])
  @@map("regimen_academico")
}

// ── Terciario ──────────────────────────────────────────────

model Carrera {
  id         String   @id @default(uuid())
  name       String
  titulo     String
  duracion   Int
  resolucion String?
  active     Boolean  @default(true)
  deletedAt  DateTime? @map("deleted_at")

  materias MateriaCarrera[]
  titulos  Titulo[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@index([name])
  @@map("carreras")
}

model MateriaCarrera {
  id           String  @id @default(uuid())
  carreraId    String  @map("carrera_id")
  subjectId    String  @map("subject_id")
  anio         Int     @map("anio")
  cuatrimestre String                    // "1C"|"2C"|"ANUAL" // @deprecated grading-foundations: reemplazado por GradingPeriodDate
  horasCatedra Int     @map("horas_catedra")
  regimen      String                    // "PROMOCIONAL"|"REGULAR"|"LIBRE"

  carrera Carrera @relation(fields: [carreraId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  correlativas      Correlatividad[] @relation("MateriaCorrelativa")
  correlativasDe    Correlatividad[] @relation("MateriaCorrelativaRequerida")
  inscripciones     InscripcionMateria[]
  actasExamen       ActaExamen[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@unique([carreraId, subjectId, anio, cuatrimestre])
  @@index([carreraId])
  @@index([subjectId])
  @@map("materias_carrera")
}

model Correlatividad {
  id            String @id @default(uuid())
  materiaId     String @map("materia_id")
  correlativaId String @map("correlativa_id")
  tipo          String                        // "CURSADA"|"FINAL"

  materia     MateriaCarrera @relation("MateriaCorrelativa",         fields: [materiaId],     references: [id], onDelete: Cascade)
  correlativa MateriaCarrera @relation("MateriaCorrelativaRequerida", fields: [correlativaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([materiaId, correlativaId])
  @@index([materiaId])
  @@map("correlatividades")
}

model InscripcionMateria {
  id              String  @id @default(uuid())
  studentId       String  @map("student_id")
  materiaCarreraId String @map("materia_carrera_id")
  cuatrimestre    String
  anioAcademico   String  @map("anio_academico")
  estado          String                           // "INSCRIPTO"|"CURSANDO"|"REGULAR"|"APROBADO"|"LIBRE"
  notaCursada     Float?  @map("nota_cursada")
  notaFinal       Float?  @map("nota_final")

  student       Student        @relation(fields: [studentId],        references: [id], onDelete: Cascade)
  materiaCarrera MateriaCarrera @relation(fields: [materiaCarreraId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@unique([studentId, materiaCarreraId, cuatrimestre, anioAcademico])
  @@index([studentId])
  @@index([materiaCarreraId])
  @@map("inscripciones_materia")
}

model ActaExamen {
  id              String   @id @default(uuid())
  materiaCarreraId String  @map("materia_carrera_id")
  fecha           DateTime
  presidenteId    String   @map("presidente_id")
  vocales         String[]
  libro           String?
  folio           String?
  active          Boolean  @default(true)
  deletedAt       DateTime? @map("deleted_at")

  materiaCarrera MateriaCarrera  @relation(fields: [materiaCarreraId], references: [id], onDelete: Cascade)
  presidente     Teacher         @relation(fields: [presidenteId],     references: [id], onDelete: Restrict)
  notas          ActaExamenNota[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@index([materiaCarreraId])
  @@index([fecha])
  @@index([presidenteId])
  @@map("actas_examen")
}

model ActaExamenNota {
  id        String  @id @default(uuid())
  actaId    String  @map("acta_id")
  studentId String  @map("student_id")
  nota      Float
  condicion String                   // "APROBADO"|"DESAPROBADO"|"AUSENTE"

  acta    ActaExamen @relation(fields: [actaId],    references: [id], onDelete: Cascade)
  student Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@unique([actaId, studentId])
  @@index([actaId])
  @@index([studentId])
  @@map("acta_examen_notas")
}

model Titulo {
  id           String    @id @default(uuid())
  studentId    String    @map("student_id")
  carreraId    String    @map("carrera_id")
  fechaEgreso  DateTime? @map("fecha_egreso")
  fechaEmision DateTime? @map("fecha_emision")
  estado       String                          // "EN_TRAMITE"|"EMITIDO"|"ENTREGADO"
  nroRegistro  String?   @map("nro_registro")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  carrera Carrera @relation(fields: [carreraId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@unique([studentId, carreraId])
  @@index([studentId])
  @@index([carreraId])
  @@map("titulos")
}

// ── Student Observations ───────────────────────────────────

model StudentObservation {
  id        String   @id @default(uuid())
  studentId String   @map("student_id")
  authorId  String   @map("author_id")
  type      String
  content   String   @db.Text
  active    Boolean  @default(true)
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([authorId])
  @@map("student_observations")
}

// ── Grading Periods ────────────────────────────────────────

model GradingPeriodTemplate {
  id        String   @id @default(uuid())
  name      String              // "Trimestral", "Cuatrimestral"
  level     Int                 // EducationalLevelCode (1-4)
  modality  Int    @default(0)  // EducationalModalityCode (0-2)
  active    Boolean @default(true)
  deletedAt DateTime?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items GradingPeriodTemplateItem[]

  @@unique([level, modality, name])
  @@index([level])
  @@map("grading_period_templates")
}

model GradingPeriodTemplateItem {
  id         String @id @default(uuid())
  templateId String @map("template_id")
  name       String              // "1° Trimestre", "2° Cuatrimestre"
  sortOrder  Int                 // ≥ 1, unique within template

  template GradingPeriodTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  dates    GradingPeriodDate[]
  competencyPeriodValuations CompetencyPeriodValuation[]

  @@unique([templateId, sortOrder])
  @@unique([templateId, name])
  @@index([templateId])
  @@map("grading_period_template_items")
}

model GradingPeriodDate {
  id        String   @id @default(uuid())
  itemId    String   @map("template_item_id")
  cycleId   String   @map("cycle_id")           // → AcademicCycle.uuid
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  item  GradingPeriodTemplateItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  cycle AcademicCycle             @relation(fields: [cycleId], references: [uuid], onDelete: Cascade)

  @@unique([itemId, cycleId])
  @@index([cycleId])
  @@map("grading_period_dates")
}
