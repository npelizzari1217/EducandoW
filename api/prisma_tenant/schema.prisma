// ── Inicial ────────────────────────────────────────────────

model Sala {
  id           String   @id @default(uuid())
  name         String
  ageGroup     Int                    @map("age_group")   // 3, 4 o 5
  turno        String                 @map("turno")       // "MAÑANA" | "TARDE"
  capacity     Int
  teacherId    String?                @map("teacher_id")
  academicYear String                 @map("academic_year")
  active       Boolean  @default(true)
  deletedAt    DateTime?              @map("deleted_at")

  teacher     Teacher?         @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  enrollments SalaEnrollment[]
  informes    InformeEvolutivo[]
  planificaciones Planificacion[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@index([academicYear])
  @@index([ageGroup])
  @@index([teacherId])
  @@map("salas")
}

model SalaEnrollment {
  id           String   @id @default(uuid())
  studentId    String   @map("student_id")
  salaId       String   @map("sala_id")
  academicYear String   @map("academic_year")
  enrolledAt   DateTime @default(now()) @map("enrolled_at")
  active       Boolean  @default(true)
  deletedAt    DateTime? @map("deleted_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  sala    Sala    @relation(fields: [salaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@unique([studentId, salaId, academicYear])
  @@index([studentId])
  @@index([salaId])
  @@map("sala_enrollments")
}

model InformeEvolutivo {
  id                    String   @id @default(uuid())
  studentId             String   @map("student_id")
  salaId                String   @map("sala_id")
  periodo               String                      // "1T" | "2T" | "3T" // @deprecated grading-foundations: reemplazado por GradingPeriodDate
  fecha                 DateTime
  observacionesGenerales String? @map("observaciones_generales")
  active                Boolean  @default(true)
  deletedAt             DateTime? @map("deleted_at")

  student Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  sala    Sala           @relation(fields: [salaId], references: [id], onDelete: Cascade)
  areas   AreaDesarrollo[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@index([studentId])
  @@index([salaId])
  @@index([periodo])
  @@map("informes_evolutivos")
}

model AreaDesarrollo {
  id         String @id @default(uuid())
  informeId  String @map("informe_id")
  area       String                    // "SOCIO_AFECTIVA"|"MOTRIZ"|"COGNITIVA"|"LENGUAJE"|"CREATIVA"
  observacion String
  valoracion String                    // "DESTACADO"|"LOGRADO"|"EN_PROCESO"|"NO_LOGRADO"

  informe InformeEvolutivo @relation(fields: [informeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@index([informeId])
  @@map("areas_desarrollo")
}

model Planificacion {
  id           String   @id @default(uuid())
  salaId       String   @map("sala_id")
  semana       Int                      // 1..40
  academicYear String   @map("academic_year")
  active       Boolean  @default(true)
  deletedAt    DateTime? @map("deleted_at")

  sala        Sala                @relation(fields: [salaId], references: [id], onDelete: Cascade)
  secuencias  SecuenciaDidactica[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@index([salaId])
  @@index([academicYear])
  @@map("planificaciones")
}

model SecuenciaDidactica {
  id              String   @id @default(uuid())
  planificacionId String   @map("planificacion_id")
  nombre          String
  area            String
  actividades     String[]
  recursos        String[]

  planificacion Planificacion @relation(fields: [planificacionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@index([planificacionId])
  @@map("secuencias_didacticas")
}

// ── Primario ───────────────────────────────────────────────

model Grado {
