}

// ── Terciario ──────────────────────────────────────────────

model Carrera {
  id         String   @id @default(uuid())
  name       String
  titulo     String
  duracion   Int
  resolucion String?
  active     Boolean  @default(true)
  deletedAt  DateTime? @map("deleted_at")

  materias MateriaCarrera[]
  titulos  Titulo[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@index([name])
  @@map("carreras")
}

model MateriaCarrera {
  id           String  @id @default(uuid())
  carreraId    String  @map("carrera_id")
  subjectId    String  @map("subject_id")
  anio         Int     @map("anio")
  cuatrimestre String                    // "1C"|"2C"|"ANUAL" // @deprecated grading-foundations: reemplazado por GradingPeriodDate
  horasCatedra Int     @map("horas_catedra")
  regimen      String                    // "PROMOCIONAL"|"REGULAR"|"LIBRE"

  carrera Carrera @relation(fields: [carreraId], references: [id], onDelete: Cascade)
