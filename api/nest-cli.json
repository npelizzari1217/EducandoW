{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "builder": "swc",
    "typeCheck": true,
    "tsConfigPath": "tsconfig.build.json",
    "assets": [
      {
        "include": "infrastructure/reporting/html-templates/**/*.hbs",
        "outDir": "dist/src"
      }
    ]
  }
}
