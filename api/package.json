{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nest build && pnpm postbuild",
    "postbuild": "node -e \"const fs=require('fs');const p=require('path');['prisma_tenant','prisma_master'].forEach(d=>{const s=p.join(__dirname,d);const t=p.join(__dirname,'dist',d);fs.cpSync(s,t,{recursive:true});console.log('Copied',d,'to dist')})\"",
    "dev": "nest start --watch",
    "start": "nest start",
    "start:prod": "node dist/src/main",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate --schema=prisma_master/schema.prisma && prisma generate --schema=prisma_tenant/schema.prisma",
    "prisma:generate:master": "prisma generate --schema=prisma_master/schema.prisma",
    "prisma:generate:tenant": "prisma generate --schema=prisma_tenant/schema.prisma",
    "prisma:migrate:master": "prisma migrate dev --schema=prisma_master/schema.prisma",
    "prisma:migrate:tenant": "prisma migrate dev --schema=prisma_tenant/schema.prisma",
    "prisma:migrate:deploy:master": "prisma migrate deploy --schema=prisma_master/schema.prisma",
    "prisma:migrate:deploy:tenant": "prisma migrate deploy --schema=prisma_tenant/schema.prisma",
    "prisma:migrate": "pnpm prisma:migrate:master",
    "prisma:seed": "ts-node prisma/seed.ts",
    "bootstrap": "tsx scripts/bootstrap.ts",
    "migrate-tenants": "tsx scripts/migrate-all-tenants.ts",
    "tenant:create": "ts-node scripts/create-tenant-db.ts",
    "diagnose:auth": "ts-node scripts/diagnose-auth.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@educandow/domain": "workspace:*",
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^5.20.0",
    "archiver": "^8.0.0",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.6",
    "handlebars": "^4.7.9",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.21.0",
    "puppeteer": "^25.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^10.4.0",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.33",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.7",
    "prisma": "^5.20.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0",
    "vitest": "^1.6.1"
  }
}
