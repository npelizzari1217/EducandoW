generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Auth ─────────────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  name          String
  role          String   @default("ADMIN") // ADMIN | MANAGER | TEACHER
  institutionId String?
  level         String?  // INICIAL | PRIMARIO | SECUNDARIO | TERCIARIO
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  institution   Institution?   @relation(fields: [institutionId], references: [id])
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  role      String   @default("TEACHER")
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ── Institution ─────────────────────────────────────────────

model Institution {
  id      String   @id @default(uuid())
  name    String
  address String?
  phone   String?
  email   String?
  levels  String[] // Array of LevelType: INICIAL, PRIMARIO, SECUNDARIO, TERCIARIO

  users       User[]
  enrollments Enrollment[]
  students    Student[]
  teachers    Teacher[]
  subjects    Subject[]
  courseSections CourseSection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("institutions")
}

// ── Personnel ──────────────────────────────────────────────

model Student {
  id            String   @id @default(uuid())
  firstName     String
  lastName      String
  dni           String   @unique
  email         String?
  birthDate     DateTime?
  guardianName  String?
  guardianPhone String?
  institutionId String

  institution Institution @relation(fields: [institutionId], references: [id])
  enrollments Enrollment[]
  grades      Grade[]
  attendances Attendance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("students")
}

model Teacher {
  id            String   @id @default(uuid())
  firstName     String
  lastName      String
  dni           String   @unique
  email         String
  phone         String?
  title         String?
  institutionId String

  institution         Institution          @relation(fields: [institutionId], references: [id])
  subjectAssignments  SubjectAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("teachers")
}

// ── Enrollment ─────────────────────────────────────────────

model Enrollment {
  id            String   @id @default(uuid())
  studentId     String
  institutionId String
  level         String   // INICIAL | PRIMARIO | SECUNDARIO | TERCIARIO
  academicYear  String
  grade         String?
  division      String?
  status        String   @default("ACTIVE") // ACTIVE | INACTIVE | GRADUATED | TRANSFERRED
  enrolledAt    DateTime @default(now())

  student     Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  institution Institution @relation(fields: [institutionId], references: [id])

  @@map("enrollments")
}

// ── Pedagogical ────────────────────────────────────────────

model Subject {
  id            String @id @default(uuid())
  name          String
  level         String // INICIAL | PRIMARIO | SECUNDARIO | TERCIARIO
  institutionId String

  institution      Institution        @relation(fields: [institutionId], references: [id])
  grades           Grade[]
  subjectAssignments SubjectAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("subjects")
}

model CourseSection {
  id            String @id @default(uuid())
  name          String // e.g. "3° A"
  grade         String?
  division      String?
  level         String
  academicYear  String
  institutionId String

  institution      Institution         @relation(fields: [institutionId], references: [id])
  grades           Grade[]
  attendances      Attendance[]
  subjectAssignments SubjectAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("course_sections")
}

model SubjectAssignment {
  id              String @id @default(uuid())
  subjectId       String
  teacherId       String
  courseSectionId String

  subject       Subject       @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher       Teacher       @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  courseSection CourseSection @relation(fields: [courseSectionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("subject_assignments")
}

model Grade {
  id              String   @id @default(uuid())
  studentId       String
  subjectId       String
  courseSectionId String
  period          String   // "1T", "2T", "3T", "FINAL", "DIC"
  numericValue    Float?
  qualitativeValue String? // "Destacado", "Logrado", etc.
  status          String?  // "APROBADO", "PREVIA", "LIBRE", "PROMOCION"
  evaluatedAt     DateTime @default(now())

  student       Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject       Subject       @relation(fields: [subjectId], references: [id])
  courseSection CourseSection @relation(fields: [courseSectionId], references: [id])

  @@map("grades")
}

model Attendance {
  id              String   @id @default(uuid())
  studentId       String
  courseSectionId String
  date            DateTime
  status          String   @default("PRESENT") // PRESENT | ABSENT | LATE | JUSTIFIED
  note            String?

  student       Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  courseSection CourseSection @relation(fields: [courseSectionId], references: [id])

  @@unique([studentId, courseSectionId, date])
  @@map("attendances")
}
