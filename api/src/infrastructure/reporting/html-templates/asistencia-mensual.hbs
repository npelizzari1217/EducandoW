<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Asistencia Mensual — {{scopeLabel}}</title>
  {{!--
    Expected context (built by GenerateAsistenciaMensualPdfUseCase, PR3c):
      institucionNombre: string
      logoDataUri?: string
      scopeLabel: string        — e.g. "5° A" (General) or "Matemática — 5° A" (Por Materia)
      mesAnioLabel: string      — e.g. "Julio 2026"
      diasHabiles: number       — computeDiasHabiles(...) result (course-level scalar)
      dayNumbers: number[]      — [1..daysInMonth], drives both the header row and each
                                   student's day-cell lookup
      alumnos: Array<{
        apellidoNombre: string
        days: Record<string, string>   — day number (as string key) -> attendance code,
                                          same shape consumed by computeStudentTotals
        tardesJust: number
        tardesInj: number
        totalTardes: number
        ausJust: number
        ausInj: number
        ausTotal: number
      }>                         — one entry per student, spreads computeStudentTotals(...)
                                   output alongside apellidoNombre/days
  --}}
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', Arial, sans-serif; font-size: 9px; padding: 18px 20px; color: #1a1a1a; }

    /* ── Header ─── */
    .header { display: flex; align-items: center; gap: 16px; margin-bottom: 14px;
              border-bottom: 2px solid #1a1a1a; padding-bottom: 10px; }
    .header-logo { flex: 0 0 auto; }
    .header-logo img { max-height: 48px; max-width: 90px; object-fit: contain; }
    .header-text { flex: 1; }
    .header-text h1 { font-size: 14px; text-transform: uppercase; letter-spacing: 0.5px; }
    .header-text h2 { font-size: 11px; font-weight: normal; color: #444; margin-top: 2px; }
    .header-meta { flex: 0 0 auto; text-align: right; font-size: 11px; }
    .header-meta .dias-habiles { font-weight: bold; margin-top: 4px; }

    /* ── Grid: alumnos × días + 6 totales ─── */
    table.attendance-grid { width: 100%; border-collapse: collapse; table-layout: fixed; }
    table.attendance-grid th,
    table.attendance-grid td {
      border: 1px solid #ccc; text-align: center; padding: 2px 1px;
      overflow: hidden; white-space: nowrap;
    }
    table.attendance-grid th { background: #1a1a1a; color: #fff; font-size: 8px; font-weight: normal; }
    table.attendance-grid th.alumno-col,
    table.attendance-grid td.alumno-col {
      text-align: left; padding-left: 4px; width: 130px; font-size: 9px;
    }
    table.attendance-grid th.day-col,
    table.attendance-grid td.day-col { width: 16px; }
    table.attendance-grid th.total-col,
    table.attendance-grid td.total-col { width: 30px; font-weight: bold; }
    table.attendance-grid td.total-col { background: #f5f5f5; }
    table.attendance-grid tbody tr:nth-child(even) td:not(.total-col) { background: #fafafa; }

    .footer { margin-top: 10px; font-size: 8px; color: #666; }

    /* ── Print ─── */
    @media print {
      body { padding: 0; }
      @page { size: A4 landscape; margin: 10mm 8mm; }
    }
  </style>
</head>
<body>

  {{!-- Header: institución + curso/materia + mes/año + días hábiles --}}
  <div class="header">
    {{#if logoDataUri}}
    <div class="header-logo">
      <img src="{{logoDataUri}}" alt="Logo institucional">
    </div>
    {{/if}}
    <div class="header-text">
      <h1>{{institucionNombre}}</h1>
      <h2>Planilla de Asistencia Mensual — {{scopeLabel}}</h2>
    </div>
    <div class="header-meta">
      <div>{{mesAnioLabel}}</div>
      <div class="dias-habiles">Días hábiles: {{diasHabiles}}</div>
    </div>
  </div>

  {{!-- Grid: alumnos (filas) × días del mes (columnas) + 6 columnas de totales --}}
  <table class="attendance-grid">
    <thead>
      <tr>
        <th class="alumno-col">Alumno</th>
        {{#each dayNumbers}}
        <th class="day-col">{{this}}</th>
        {{/each}}
        <th class="total-col">Tardes Just.</th>
        <th class="total-col">Tardes Inj.</th>
        <th class="total-col">Total Tardes</th>
        <th class="total-col">Aus. Just.</th>
        <th class="total-col">Aus. Inj.</th>
        <th class="total-col">Aus. Total</th>
      </tr>
    </thead>
    <tbody>
      {{#each alumnos}}
      <tr>
        <td class="alumno-col">{{apellidoNombre}}</td>
        {{#each ../dayNumbers}}
        <td class="day-col">{{lookup ../days this}}</td>
        {{/each}}
        <td class="total-col">{{tardesJust}}</td>
        <td class="total-col">{{tardesInj}}</td>
        <td class="total-col">{{totalTardes}}</td>
        <td class="total-col">{{ausJust}}</td>
        <td class="total-col">{{ausInj}}</td>
        <td class="total-col">{{ausTotal}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>

  <div class="footer">
    Tardes: Just. = Justificadas · Inj. = Injustificadas · Total = suma ponderada. Ausencias: ídem criterio.
  </div>

</body>
</html>
