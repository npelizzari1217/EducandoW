<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Boletín de Calificaciones — {{grado}}</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', Arial, sans-serif; font-size: 13px; padding: 40px; color: #1a1a1a; }
    .header { text-align: center; margin-bottom: 30px; border-bottom: 2px solid #1a1a1a; padding-bottom: 15px; }
    .header h1 { font-size: 18px; margin-bottom: 4px; text-transform: uppercase; }
    .header h2 { font-size: 14px; font-weight: normal; color: #444; }
    .student-info { margin-bottom: 25px; padding: 12px; background: #f5f5f5; border-radius: 4px; }
    .student-info table { width: 100%; border-collapse: collapse; }
    .student-info td { padding: 4px 8px; }
    .student-info td:first-child { font-weight: bold; width: 120px; }
    .section-title { font-size: 15px; font-weight: bold; margin-bottom: 10px; margin-top: 20px; border-bottom: 1px solid #ccc; padding-bottom: 4px; }
    table.grades { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
    table.grades th { background: #1a1a1a; color: white; padding: 8px 10px; text-align: left; font-size: 12px; }
    table.grades td { padding: 7px 10px; border-bottom: 1px solid #e0e0e0; }
    table.grades tr:nth-child(even) { background: #fafafa; }
    .footer { margin-top: 40px; font-size: 11px; color: #666; }
    .signature-line { display: inline-block; margin-top: 50px; width: 230px; border-top: 1px solid #1a1a1a; padding-top: 4px; text-align: center; font-size: 12px; margin-right: 40px; }
    .approved { color: #2e7d32; font-weight: bold; }
    .failed { color: #c62828; font-weight: bold; }
  </style>
</head>
<body>
  <div class="header">
    <h1>{{institucionNombre}}</h1>
    <h2>Boletín de Calificaciones — {{grado}}</h2>
  </div>

  <div class="student-info">
    <table>
      <tr><td>Alumno:</td><td>{{alumnoApellido}}, {{alumnoNombre}}</td></tr>
      <tr><td>DNI:</td><td>{{alumnoDni}}</td></tr>
      <tr><td>Curso:</td><td>{{grado}}</td></tr>
      <tr><td>Período:</td><td>{{periodo}}</td></tr>
    </table>
  </div>

  <div class="section-title">Calificaciones</div>
  <table class="grades">
    <thead>
      <tr>
        <th>Materia</th>
        <th>Promedio</th>
        <th>Condición</th>
        <th>Valoración</th>
      </tr>
    </thead>
    <tbody>
      {{#each materias}}
      <tr>
        <td>{{nombre}}</td>
        <td>{{promedio}}</td>
        <td class="{{#if aprobado}}approved{{else}}failed{{/if}}">
          {{#if aprobado}}APROBADO{{else}}PREVIAS{{/if}}
        </td>
        <td>{{valoracion}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>

  <div class="footer">
    <p>{{periodo}} — Institución: {{institucionNombre}}</p>
  </div>

  <div class="signature-line">Firma del preceptor</div>
  <div class="signature-line">Firma del director</div>
</body>
</html>
