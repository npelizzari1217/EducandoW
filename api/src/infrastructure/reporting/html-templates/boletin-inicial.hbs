<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Informe Evolutivo — {{institucionNombre}}</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', Arial, sans-serif; font-size: 13px; padding: 40px; color: #1a1a1a; }
    .header { text-align: center; margin-bottom: 30px; border-bottom: 2px solid #1a1a1a; padding-bottom: 15px; }
    .header h1 { font-size: 18px; margin-bottom: 4px; text-transform: uppercase; }
    .header h2 { font-size: 14px; font-weight: normal; color: #444; }
    .student-info { margin-bottom: 25px; padding: 12px; background: #f5f5f5; border-radius: 4px; }
    .student-info table { width: 100%; border-collapse: collapse; }
    .student-info td { padding: 4px 8px; }
    .student-info td:first-child { font-weight: bold; width: 140px; }
    .section-title { font-size: 15px; font-weight: bold; margin-bottom: 10px; margin-top: 20px; border-bottom: 1px solid #ccc; padding-bottom: 4px; }
    .obs-generales { margin-bottom: 12px; padding: 8px 10px; background: #f9f9f9; border-left: 3px solid #ccc; font-style: italic; }
    table.grades { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
    table.grades th { background: #1a1a1a; color: white; padding: 8px 10px; text-align: left; font-size: 12px; }
    table.grades td { padding: 7px 10px; border-bottom: 1px solid #e0e0e0; }
    table.grades tr:nth-child(even) { background: #fafafa; }
    .empty-state { padding: 12px 10px; color: #888; font-style: italic; margin-bottom: 20px; }
    .footer { margin-top: 40px; font-size: 11px; color: #666; }
  </style>
</head>
<body>
  <div class="header">
    <h1>{{institucionNombre}}</h1>
    <h2>Informe Evolutivo — Nivel Inicial</h2>
  </div>

  <div class="student-info">
    <table>
      <tr><td>Alumno:</td><td>{{alumnoApellido}}, {{alumnoNombre}}</td></tr>
      <tr><td>DNI:</td><td>{{alumnoDni}}</td></tr>
      <tr><td>Sala:</td><td>{{grado}}</td></tr>
      <tr><td>Ciclo lectivo:</td><td>{{periodo}}</td></tr>
    </table>
  </div>

  {{#each informesInicial}}
  <div class="section-title">Informe — {{this.periodo}} · {{this.fecha}}</div>
  {{#if this.observacionesGenerales}}
  <p class="obs-generales">{{this.observacionesGenerales}}</p>
  {{/if}}
  <table class="grades">
    <thead>
      <tr><th>Área</th><th>Observación</th><th>Valoración</th></tr>
    </thead>
    <tbody>
      {{#each this.areas}}
      <tr>
        <td>{{this.nombre}}</td>
        <td>{{this.observacion}}</td>
        <td>{{this.valoracion}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{else}}
  <p class="empty-state">Sin informes evolutivos cargados para este ciclo.</p>
  {{/each}}

  {{#if asistencia}}
  <div class="section-title">Asistencia</div>
  <table class="grades">
    <thead>
      <tr><th>Total clases</th><th>Presente</th><th>Inasistencias</th><th>1/2 Faltas</th><th>Porcentaje</th></tr>
    </thead>
    <tbody>
      <tr>
        <td>{{asistencia.totalDias}}</td>
        <td>{{asistencia.diasPresente}}</td>
        <td>{{asistencia.inasistencias}}</td>
        <td>{{asistencia.mediasFaltas}}</td>
        <td>{{asistencia.porcentaje}}%</td>
      </tr>
    </tbody>
  </table>
  {{/if}}

  <div class="footer">
    <p>Ciclo lectivo {{periodo}} — Institución: {{institucionNombre}}</p>
  </div>
</body>
</html>
