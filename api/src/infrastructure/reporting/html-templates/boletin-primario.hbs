<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Boletín de Calificaciones — {{grado}}</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', Arial, sans-serif; font-size: 12px; padding: 36px; color: #1a1a1a; }
    .header { text-align: center; margin-bottom: 26px; border-bottom: 2px solid #1a1a1a; padding-bottom: 14px; }
    .header h1 { font-size: 17px; margin-bottom: 4px; text-transform: uppercase; }
    .header h2 { font-size: 13px; font-weight: normal; color: #444; }
    .student-info { margin-bottom: 22px; padding: 10px; background: #f5f5f5; border-radius: 4px; }
    .student-info table { width: 100%; border-collapse: collapse; }
    .student-info td { padding: 3px 8px; }
    .student-info td:first-child { font-weight: bold; width: 120px; }
    .section-title { font-size: 14px; font-weight: bold; margin-bottom: 8px; margin-top: 18px; border-bottom: 1px solid #ccc; padding-bottom: 3px; }
    table.grades { width: 100%; border-collapse: collapse; margin-bottom: 18px; }
    table.grades th { background: #1a1a1a; color: white; padding: 6px 8px; text-align: center; font-size: 11px; }
    table.grades th.left { text-align: left; }
    table.grades td { padding: 6px 8px; border-bottom: 1px solid #e0e0e0; text-align: center; }
    table.grades td.left { text-align: left; }
    table.grades tr:nth-child(even) { background: #fafafa; }
    td.blank { color: #aaa; }
    .flags { font-size: 11px; color: #555; }
    .flag-badge { display: inline-block; background: #e8f5e9; color: #2e7d32; border: 1px solid #a5d6a7;
                  border-radius: 3px; padding: 1px 5px; margin-right: 3px; font-size: 10px; font-weight: bold; }
    .footer { margin-top: 36px; font-size: 10px; color: #666; }
    .signature-line { display: inline-block; margin-top: 46px; width: 220px; border-top: 1px solid #1a1a1a;
                      padding-top: 4px; text-align: center; font-size: 11px; margin-right: 36px; }
  </style>
</head>
<body>
  <div class="header">
    <h1>{{institucionNombre}}</h1>
    <h2>Boletín de Calificaciones — Nivel Primario — {{grado}}</h2>
  </div>

  <div class="student-info">
    <table>
      <tr><td>Alumno:</td><td>{{alumnoApellido}}, {{alumnoNombre}}</td></tr>
      <tr><td>DNI:</td><td>{{alumnoDni}}</td></tr>
      <tr><td>Grado:</td><td>{{grado}}</td></tr>
      <tr><td>Período:</td><td>{{periodo}}</td></tr>
    </table>
  </div>

  {{#if materias}}
  <div class="section-title">Calificaciones por período</div>
  <table class="grades">
    <thead>
      <tr>
        <th class="left">Materia</th>
        {{#with (lookup materias 0)}}
          {{#each periodGrades}}
          <th>{{periodName}}</th>
          {{/each}}
        {{/with}}
        <th>Final</th>
        <th>Diciembre</th>
        <th>Marzo</th>
        <th>Definitiva</th>
        <th>Flags</th>
      </tr>
    </thead>
    <tbody>
      {{#each materias}}
      <tr>
        <td class="left">{{nombre}}</td>
        {{#each periodGrades}}
        <td>{{#if gradeCode}}{{gradeCode}}{{else}}<span class="blank">—</span>{{/if}}</td>
        {{/each}}
        {{#each finalGrades}}
        <td>{{#if gradeCode}}{{gradeCode}}{{else}}<span class="blank">—</span>{{/if}}</td>
        {{/each}}
        <td class="flags">
          {{#if flags}}
            {{#if flags.pa}}<span class="flag-badge">PA</span>{{/if}}
            {{#if flags.ppi}}<span class="flag-badge">PPI</span>{{/if}}
            {{#if flags.pp}}<span class="flag-badge">PP</span>{{/if}}
          {{/if}}
        </td>
      </tr>
      {{/each}}
    </tbody>
  </table>

  {{#each materias}}
  {{#if competencies}}
  <div class="section-title">Competencias — {{nombre}}</div>
  <table class="grades">
    <thead>
      <tr>
        <th class="left">Competencia</th>
        {{#each periodGrades}}
        <th>{{periodName}}</th>
        {{/each}}
      </tr>
    </thead>
    <tbody>
      {{#each competencies}}
      <tr>
        <td class="left">{{competencyName}}</td>
        {{#each periodGrades}}
        <td>{{#if gradeCode}}{{gradeCode}}{{else}}<span class="blank">—</span>{{/if}}</td>
        {{/each}}
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{/if}}
  {{/each}}
  {{/if}}

  {{#if asistencia}}
  <div class="section-title">Asistencia</div>
  <table class="grades">
    <thead>
      <tr><th>Total clases</th><th>Presente</th><th>Inasistencias</th><th>1/2 Faltas</th><th>Porcentaje</th></tr>
    </thead>
    <tbody>
      <tr>
        <td>{{asistencia.totalDias}}</td>
        <td>{{asistencia.diasPresente}}</td>
        <td>{{asistencia.inasistencias}}</td>
        <td>{{asistencia.mediasFaltas}}</td>
        <td>{{asistencia.porcentaje}}%</td>
      </tr>
    </tbody>
  </table>
  {{/if}}

  <div class="footer">
    <p>{{periodo}} — Institución: {{institucionNombre}}</p>
  </div>

  <div class="signature-line">Firma del docente</div>
  <div class="signature-line">Firma del director</div>
</body>
</html>
