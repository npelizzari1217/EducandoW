{
  "name": "@educandow/domain",
  "version": "0.0.1",
  "private": true,
  "description": "Pure domain layer — zero external dependencies",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./asistencia/utils/calendar-utils": {
      "types": "./dist/asistencia/utils/calendar-utils.d.ts",
      "default": "./dist/asistencia/utils/calendar-utils.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "typescript": "~5.9.3",
    "vitest": "^4.1.7"
  }
}
