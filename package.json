{
  "name": "educandow",
  "private": true,
  "workspaces": [
    "packages/*",
    "api",
    "web"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "lint:eslint": "eslint .",
    "lint:typecheck": "turbo run lint",
    "clean": "turbo run clean",
    "dev": "turbo run dev",
    "format": "prettier --write \"**/*.{ts,tsx,json}\"",
    "fix-perms": "node scripts/fix-binary-perms.js",
    "postinstall": "node scripts/fix-binary-perms.js || true"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@mermaid-js/mermaid-cli": "^11.15.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.0.0",
    "turbo": "^2.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.0.0"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.0.0"
  }
}
